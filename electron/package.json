{
  "name": "privacylens-electron",
  "version": "1.0.0",
  "main": "main.js",
  "preload": "preload.js",
  "homepage": "./",
  "dependencies": {
    "electron-squirrel-startup": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm start --prefix ../frontend\" \"electron .\"",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.privacylens.app",
    "productName": "PrivacyLens",
    "files": [
      "main.js",
      "preload.js",
      "../frontend/build/**/*",
      "../backend/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
